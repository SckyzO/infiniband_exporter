{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "Prometheus data source scraping infiniband_exporter.", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "heatmap", "name": "Heatmap", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Fleet-wide health and throughput for an InfiniBand fabric scraped by SckyzO/infiniband_exporter. Sized for 40+ switches: per-switch line plots are replaced by heatmaps + min/avg/max stats and topk() panels so the dashboard stays readable. For ≤40 switches, prefer the -small variant.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {"title": "Switch detail", "url": "/d/ib-switch-detail", "type": "dashboards", "tags": ["infiniband"]},
    {"title": "HCA detail", "url": "/d/ib-hca-detail", "type": "dashboards", "tags": ["infiniband"]}
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Switches up",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(infiniband_switch_up)", "legendFormat": "up", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "count(infiniband_switch_up) - sum(infiniband_switch_up)", "legendFormat": "down", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "count(infiniband_switch_up)", "legendFormat": "total", "refId": "C"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value_and_name", "colorMode": "value", "orientation": "horizontal", "graphMode": "none"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "overrides": [{"matcher": {"id": "byName", "options": "down"}, "properties": [{"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}]}]}, "overrides": []}
    },
    {
      "id": 2, "type": "stat", "title": "HCAs up",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(infiniband_hca_up)", "legendFormat": "up", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "count(infiniband_hca_up) - sum(infiniband_hca_up)", "legendFormat": "down", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "count(infiniband_hca_up)", "legendFormat": "total", "refId": "C"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value_and_name", "colorMode": "value", "orientation": "horizontal", "graphMode": "none"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []}
    },
    {
      "id": 3, "type": "stat", "title": "Fabric Tx",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(infiniband_switch_port_transmit_data_bytes_total[5m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 4, "type": "stat", "title": "Fabric Rx",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(infiniband_switch_port_receive_data_bytes_total[5m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 5, "type": "stat", "title": "Temp min / avg / max",
      "description": "ASIC temperature spread across all switches reporting (requires --collector.ibswinfo).",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "min(infiniband_switch_temperature_celsius)", "legendFormat": "min", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "avg(infiniband_switch_temperature_celsius)", "legendFormat": "avg", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "max(infiniband_switch_temperature_celsius)", "legendFormat": "max", "refId": "C"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "value_and_name", "colorMode": "value", "orientation": "horizontal", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "celsius", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}, "overrides": []}
    },
    {
      "id": 6, "type": "timeseries", "title": "Fabric throughput",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(infiniband_switch_port_transmit_data_bytes_total[5m]))", "legendFormat": "Tx", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(infiniband_switch_port_receive_data_bytes_total[5m]))", "legendFormat": "Rx", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "Top 20 switches by error rate",
      "description": "Sum of headline error counters per switch, ranked.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "topk(20, sum by (switch) (rate(infiniband_switch_port_symbol_error_total[5m]) + rate(infiniband_switch_port_link_downed_total[5m]) + rate(infiniband_switch_port_link_error_recovery_total[5m]) + rate(infiniband_switch_port_receive_errors_total[5m]) + rate(infiniband_switch_port_transmit_discards_total[5m])))", "legendFormat": "{{switch}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 0, "lineWidth": 2}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 8, "type": "heatmap", "title": "Switch ASIC temperatures (heatmap)",
      "description": "Distribution of switch temperatures over time. Brighter cells = more switches at that temperature.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_switch_temperature_celsius", "format": "time_series", "legendFormat": "{{switch}}", "refId": "A"}
      ],
      "options": {
        "calculate": true,
        "calculation": {"yBuckets": {"mode": "size", "value": "5"}},
        "color": {"scheme": "Spectral", "mode": "scheme", "exponent": 0.5, "reverse": true, "steps": 64},
        "yAxis": {"unit": "celsius", "decimals": 0},
        "cellGap": 1,
        "cellValues": {"unit": "short"},
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9},
        "legend": {"show": true},
        "rowsFrame": {"layout": "auto"},
        "tooltip": {"show": true, "yHistogram": false}
      },
      "fieldConfig": {"defaults": {"custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}, "scaleDistribution": {"type": "linear"}}}, "overrides": []}
    },
    {
      "id": 9, "type": "timeseries", "title": "Top 20 most congested switches (PortXmitWait)",
      "description": "PortXmitWait increments while there is data to transmit but no flow-control credits available. Sustained large rates indicate the switch is a path bottleneck.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "topk(20, sum by (switch) (rate(infiniband_switch_port_transmit_wait_total[5m])))", "legendFormat": "{{switch}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 2}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 10, "type": "timeseries", "title": "Top 20 switches by packet rate (Tx)",
      "description": "Top talkers by packets per second — small-message workloads (RDMA control, MPI all-to-all) often show up here even when the byte-rate panel does not.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "topk(20, sum by (switch) (rate(infiniband_switch_port_transmit_packets_total[5m])))", "legendFormat": "{{switch}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "pps", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 2}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "right"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11, "type": "table", "title": "Failed PSUs / fans",
      "description": "Lists every switch component currently reporting non-OK status. Empty table = all healthy. Requires --collector.ibswinfo.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_switch_power_supply_status_info{status!~\"OK|ok\"} == 1", "instant": true, "format": "table", "legendFormat": "PSU status", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_switch_power_supply_dc_power_status_info{status!~\"OK|ok\"} == 1", "instant": true, "format": "table", "legendFormat": "DC power", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_switch_power_supply_fan_status_info{status!~\"OK|ok\"} == 1", "instant": true, "format": "table", "legendFormat": "PSU fan", "refId": "C"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_switch_fan_status_info{status!~\"OK|ok\"} == 1", "instant": true, "format": "table", "legendFormat": "Switch fan", "refId": "D"}
      ],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "instance": true, "job": true}}}
      ],
      "options": {"showHeader": true, "footer": {"show": false}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["infiniband", "fabric", "large"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "InfiniBand — Fabric Overview (large)",
  "uid": "ib-fabric-overview-large",
  "version": 1,
  "weekStart": ""
}
