{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "Prometheus data source scraping both node_exporter and infiniband_exporter on the management node.", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Health of an InfiniBand management node — the host that runs both node_exporter and infiniband_exporter. Combines OS-level signals (CPU, RAM, load, filesystem, IB driver counters from node_exporter's infiniband collector) with the exporter's own scrape latency / errors so 'why is my fabric scrape slow' is answerable on a single page.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [{"title": "Fabric overview", "url": "/d/ib-fabric-overview-small", "type": "dashboards", "tags": ["infiniband"]}],
  "liveNow": false,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Management node",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1, "type": "stat", "title": "Load (1m)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "node_load1{instance=~\"$instance\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 4}, {"color": "red", "value": 8}]}}, "overrides": []}
    },
    {
      "id": 2, "type": "gauge", "title": "CPU busy",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[5m])) * 100)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}, "overrides": []}
    },
    {
      "id": 3, "type": "gauge", "title": "Memory used",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}}, "overrides": []}
    },
    {
      "id": 4, "type": "stat", "title": "Uptime",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "time() - node_boot_time_seconds{instance=~\"$instance\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 5, "type": "stat", "title": "Build (infiniband_exporter)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 1},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "go_build_info{path=~\".*infiniband_exporter.*\",instance=~\"$instance\"}", "instant": true, "legendFormat": "{{version}}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "name", "colorMode": "none", "graphMode": "none"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 6, "type": "timeseries", "title": "Load average vs CPU count",
      "description": "If load1 stays above the CPU count, the management node is over-subscribed and scrape latency is going to suffer.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "node_load1{instance=~\"$instance\"}", "legendFormat": "load1", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "node_load5{instance=~\"$instance\"}", "legendFormat": "load5", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "node_load15{instance=~\"$instance\"}", "legendFormat": "load15", "refId": "C"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "count without (cpu,mode) (node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"})", "legendFormat": "cpu count", "refId": "D"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": [{"matcher": {"id": "byName", "options": "cpu count"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}]}]},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "CPU breakdown",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum by (mode) (rate(node_cpu_seconds_total{instance=~\"$instance\",mode!=\"idle\"}[5m]))", "legendFormat": "{{mode}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 30, "lineWidth": 1, "stacking": {"mode": "normal", "group": "A"}}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 200,
      "type": "row",
      "title": "infiniband_exporter health",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8, "type": "timeseries", "title": "Per-collector scrape duration",
      "description": "If a collector creeps above your Prometheus scrape_timeout the corresponding metrics start coming back stale. Common culprit: ibswinfo on a too-low max-concurrent.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_exporter_collector_duration_seconds{instance=~\"$instance\"}", "legendFormat": "{{collector}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 9, "type": "timeseries", "title": "Collect errors / timeouts",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_exporter_collect_errors{instance=~\"$instance\"}", "legendFormat": "{{collector}} errors", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_exporter_collect_timeouts{instance=~\"$instance\"}", "legendFormat": "{{collector}} timeouts", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 300,
      "type": "row",
      "title": "InfiniBand kernel driver (node_exporter infiniband collector)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10, "type": "timeseries", "title": "Driver-level Tx / Rx",
      "description": "Throughput as seen by the host's IB kernel driver (node_exporter infiniband collector). Compare against the fabric-side perfquery numbers — a divergence means a packet is being dropped between the wire and the kernel.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_infiniband_port_data_transmitted_bytes_total{instance=~\"$instance\"}[5m])", "legendFormat": "Tx {{device}}/{{port}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_infiniband_port_data_received_bytes_total{instance=~\"$instance\"}[5m])", "legendFormat": "Rx {{device}}/{{port}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 11, "type": "timeseries", "title": "Driver-level errors",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_infiniband_port_packets_received_with_errors_total{instance=~\"$instance\"}[5m])", "legendFormat": "rcv errors {{device}}/{{port}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_infiniband_port_packets_transmitted_discards_total{instance=~\"$instance\"}[5m])", "legendFormat": "discards {{device}}/{{port}}", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_infiniband_port_link_downed_total{instance=~\"$instance\"}[5m])", "legendFormat": "link down {{device}}/{{port}}", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 400,
      "type": "row",
      "title": "Filesystem & disk I/O",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12, "type": "timeseries", "title": "Filesystem usage",
      "description": "Watch the filesystem hosting --exporter.output (the textfile collector path). A full disk silently breaks runonce mode.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "100 * (1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|devtmpfs\",instance=~\"$instance\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|devtmpfs\",instance=~\"$instance\"})", "legendFormat": "{{mountpoint}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 95}]}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 13, "type": "timeseries", "title": "Disk I/O",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\"}[5m])", "legendFormat": "read {{device}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(node_disk_written_bytes_total{instance=~\"$instance\"}[5m])", "legendFormat": "write {{device}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["infiniband", "node_exporter", "management"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(infiniband_exporter_collector_duration_seconds, instance)", "refId": "StandardVariableQuery"},
        "refresh": 1,
        "label": "Management node",
        "sort": 1,
        "current": {"selected": false, "text": "", "value": ""},
        "options": [],
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "InfiniBand & node_exporter — Management node",
  "uid": "ib-and-node",
  "version": 1,
  "weekStart": ""
}
