{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "Prometheus data source scraping infiniband_exporter.", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Per-HCA view of an InfiniBand fabric — throughput, packets, errors, uplink.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [{"title": "Fabric overview", "url": "/d/ib-fabric-overview", "type": "dashboards", "tags": ["infiniband"]}],
  "liveNow": false,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Up",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_hca_up{hca=\"$hca\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "none"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "mappings": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}]}, "overrides": []}
    },
    {
      "id": 2, "type": "stat", "title": "Port rate (capacity)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_hca_port_rate_bytes_per_second{hca=\"$hca\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 3, "type": "stat", "title": "Tx",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(infiniband_hca_port_transmit_data_bytes_total{hca=\"$hca\"}[5m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 4, "type": "stat", "title": "Rx",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "sum(rate(infiniband_hca_port_receive_data_bytes_total{hca=\"$hca\"}[5m]))", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []}
    },
    {
      "id": 5, "type": "timeseries", "title": "Throughput",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_transmit_data_bytes_total{hca=\"$hca\"}[5m])", "legendFormat": "port {{port}} Tx", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_receive_data_bytes_total{hca=\"$hca\"}[5m])", "legendFormat": "port {{port}} Rx", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 6, "type": "timeseries", "title": "Packets",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_unicast_transmit_packets_total{hca=\"$hca\"}[5m])", "legendFormat": "port {{port}} ucast Tx", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_unicast_receive_packets_total{hca=\"$hca\"}[5m])", "legendFormat": "port {{port}} ucast Rx", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_multicast_transmit_packets_total{hca=\"$hca\"}[5m])", "legendFormat": "port {{port}} mcast Tx", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "pps", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "Errors (rate 5m, non-zero only)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_symbol_error_total{hca=\"$hca\"}[5m]) > 0", "legendFormat": "port {{port}} symbol", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_link_downed_total{hca=\"$hca\"}[5m]) > 0", "legendFormat": "port {{port}} link_downed", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_receive_errors_total{hca=\"$hca\"}[5m]) > 0", "legendFormat": "port {{port}} rcv", "refId": "C"},
        {"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "rate(infiniband_hca_port_transmit_discards_total{hca=\"$hca\"}[5m]) > 0", "legendFormat": "port {{port}} discards", "refId": "D"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "fillOpacity": 5, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 8, "type": "table", "title": "Uplink",
      "description": "Identifies the switch port this HCA is connected to.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 20},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "infiniband_hca_uplink_info{hca=\"$hca\"}", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "instance": true, "job": true}}}],
      "options": {"showHeader": true, "footer": {"show": false}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["infiniband", "hca"],
  "templating": {
    "list": [
      {
        "name": "hca",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(infiniband_hca_info, hca)", "refId": "StandardVariableQuery"},
        "refresh": 1,
        "label": "HCA",
        "sort": 1,
        "current": {"selected": false, "text": "", "value": ""},
        "options": [],
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "InfiniBand — HCA detail",
  "uid": null,
  "version": 1,
  "weekStart": ""
}
